{
  "name": "mandaja-firebase-seguranca",
  "version": "0.1.0",
  "private": true,
  "description": "Regras de seguranca e testes locais do Firebase para o MandaJa.",
  "type": "module",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "emuladores": "firebase emulators:start --project demo-manda-ja --only firestore,storage",
    "test": "npm run test:regras",
    "test:regras:node": "node --test --test-concurrency=1 tests/firestore.rules.test.mjs tests/storage.rules.test.mjs",
    "test:regras": "firebase emulators:exec --project demo-manda-ja --only firestore,storage \"npm run test:regras:node\""
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "firebase": "^12.16.0",
    "firebase-tools": "^15.24.0"
  }
}
